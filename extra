<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Question</title>

<style>
:root {
  /* DARK (default) */
  --bg: #0f172a;
  --text: white;
  --card: #1e293b;
  --input: #0f172a;
  --border: #334155;
  --output: #111;
}

.light {
  /* LIGHT MODE */
  --bg: #f8fafc;
  --text: #0f172a;
  --card: #ffffff;
  --input: #ffffff;
  --border: #cbd5f5;
  --output: #e2e8f0;
}

/* JUST replace colors with variables */
body {
  background: var(--bg);
  color: var(--text);
  font-family: sans-serif;
}

.container {
  display:flex;
  gap:20px;
}

.left, .right {
  width:50%;
  background: var(--card);
  padding:15px;
  border-radius:8px;
}

textarea {
  width:100%;
  height:250px;
  background: var(--input);
  color: var(--text);
  border:1px solid var(--border);
}

button {
  margin-top:10px;
  padding:10px;
  cursor:pointer;
}

#output {
  margin-top:20px;
  padding:10px;
  background: var(--output);
  border-radius:6px;
}
</style></style>
</head>

<body>

<h1 id="q-title"></h1>

<div style="margin: 20px;">
  <div style="background:#1e293b; height:10px; border-radius:10px;">
    <div id="progress-fill" style="height:100%; width:0%; background:linear-gradient(90deg,#38bdf8,#6366f1); border-radius:10px;"></div>
  </div>
  <p id="progress-text"></p>
</div>

<div class="container">

  <!-- LEFT -->
  <div class="left">
    <h3>Description</h3>
    <p id="q-desc"></p>

    <h4>Example</h4>
    <p id="q-example"></p>

    <h4>Constraints</h4>
    <ul id="q-constraints"></ul>
  </div>

  <!-- RIGHT (dynamic) -->
  <div class="right" id="right-panel"></div>

</div>

<div id="output">Output will appear here...</div>

<div style="margin-top:20px;">
  <button onclick="nextQuestion()">Next Question →</button>
</div>
<script src="script.js"></script>
</body>
</html>